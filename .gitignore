# Ignores all logfiles and tempfiles created by Rails.
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep
/tmp/cache/*
!/tmp/cache/.keep
/tmp/screenshots/*
/tmp/capybara/*
/tmp/storage/*
!/tmp/storage/.keep

# Ignore pidfiles, but keep the directory.
/public/pids
*.pid
*.seed
*.pid.lock

# Ignore bundler config.
/.bundle
/.bundle/
vendor/bundle/
/.gem
.gems
*.gem

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-*
/db/*.sqlite
/db/*.db
db/schema.rb

# Ignore all logfiles and tempfiles created by other tools.
*.log
*.pot
*.mo
*.pot.json

# Ignore byebug and pry debug history file.
.byebug_history
.pry_history
.pry-history

# Ignore RuboCop cache.
.rubocop-http*

# Ignore Spring generated files.
spring/*.pid

# Ignore uploaded files and storage in development.
/storage
/storage/*
!/storage/.keep

# Credentials and secrets
/config/master.key
/config/credentials/*.key
config/credentials.yml.enc
config/credentials/*
!config/credentials.enc.example

# Environment variables
.env
.env.local
.env.*.local
.env*
!.env*.erb

# IDEs and editors
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.iml
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/

# Node and Yarn
/node_modules
node_modules/
*.yarn-integrity
yarn-error.log
.yarnrc.yml
/yarn.lock

# Assets
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep
node_modules/.vite/

# Testing
.rspec
/spec/examples.txt
.rspec_status
/spec/support
rspec-results.xml
/test/fixtures/files

# Code coverage
/coverage
.coverage
/.simplecov
coverage/
.nyc_output/

# Tailwind CSS
.tailwindcss-cache
/public/assets/tailwind.css
tailwind_config.js.map

# Security scanning
brakeman-report.html

# Docker
docker-compose.override.yml

# Development
/.devcontainer
/.github

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
tailwindcss