<body>

    <section class="hero-gradient h-[80vh] flex flex-col items-center justify-center text-center px-4">
        <h1 class="text-5xl md:text-7xl text-yellow-500 mb-6">Forge Your Legend.</h1>
        <p class="text-xl md:text-2xl max-w-2xl text-gray-300 mb-10">
            Stop digging through stacks of paper. Track your party's progress, manage character sheets, and chronicle your world in one enchanted interface.
        </p>
        <div class="flex flex-col md:flex-row gap-4">
            <button class="bg-yellow-600 hover:bg-yellow-700 text-white px-10 py-4 rounded-lg text-lg font-bold shadow-lg transition">
                Campaigns
            </button>
            <button class="bg-yellow-600 hover:bg-yellow-700 text-white px-10 py-4 rounded-lg text-lg font-bold shadow-lg transition">
                Characters
            </button>
            <button class="bg-transparent border border-white hover:bg-white hover:text-black px-10 py-4 rounded-lg text-lg font-bold transition">
                Watch Demo
            </button>
        </div>
    </section>

    <section id="features" class="py-20 px-8 max-w-7xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-4xl text-yellow-500 mb-4">Master Your Adventure</h2>
            <p class="text-gray-400">Everything a Dungeon Master or Player needs to stay immersed.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            <div class="card-blur p-8 rounded-xl text-center">
                <div class="text-4xl mb-4">⚔️</div>
                <h3 class="text-2xl mb-4 text-yellow-200">Dynamic Character Sheets</h3>
                <p class="text-gray-400 leading-relaxed">
                    Auto-calculating stats, spell slots, and inventory. Level up with a single click without touching a calculator.
                </p>
            </div>

            <div class="card-blur p-8 rounded-xl text-center">
                <div class="text-4xl mb-4">📜</div>
                <h3 class="text-2xl mb-4 text-yellow-200">World Chronology</h3>
                <p class="text-gray-400 leading-relaxed">
                    A shared timeline for your campaign. Record NPCs met, cities visited, and those "natural 1" moments you'll never forget.
                </p>
            </div>

            <div class="card-blur p-8 rounded-xl text-center">
                <div class="text-4xl mb-4">🎲</div>
                <h3 class="text-2xl mb-4 text-yellow-200">Real-Time Dice Sync</h3>
                <p class="text-gray-400 leading-relaxed">
                    Roll within the app and see the results instantly in the DM's log. Perfect for remote sessions or hybrid play.
                </p>
            </div>
        </div>
    </section>

    <section id="campaigns" class="bg-gray-800 py-20 px-8">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
                <h2 class="text-4xl text-yellow-500 mb-6">The DM's Command Center</h2>
                <ul class="space-y-4">
                    <li class="flex items-start">
                        <span class="text-yellow-500 mr-3">✦</span>
                        <span>Track Initiative and Combat rounds effortlessly.</span>
                    </li>
                    <li class="flex items-start">
                        <span class="text-yellow-500 mr-3">✦</span>
                        <span>Manage hidden NPC stats and private DM notes.</span>
                    </li>
                    <li class="flex items-start">
                        <span class="text-yellow-500 mr-3">✦</span>
                        <span>Generate loot tables and random encounters on the fly.</span>
                    </li>
                </ul>
            </div>
            <!-- <div class="md:w-1/2">
                <div class="bg-gray-900 p-4 rounded-lg shadow-2xl border border-gray-700">
                    <img src="https://images.unsplash.com/photo-1614850523296-d8c1af93d400?auto=format&fit=crop&q=80&w=800" alt="App Preview" class="rounded border border-gray-800">
                </div>
            </div> -->
        </div>
    </section>
    <script type="text/javascript" src="../../javascript/application.js"></script>
