<div class="pt-[20vh] px-8 pb-12">
  <div class="flex flex-col md:flex-row justify-center items-start gap-8 max-w-6xl mx-auto">
    
    <section id="login-form" class="w-full md:w-1/2 max-w-md bg-gray-800 border border-gray-700 rounded-lg shadow-2xl p-8">
      <h1 class="text-3xl font-bold text-yellow-500 mb-6 font-['MedievalSharp']">Sign up</h1>
      <form class="flex flex-col space-y-4" action="/sign_up_process" method="POST">
        <div>
          <label for="email" class="block text-sm font-semibold text-gray-400 mb-1">Email</label>
          <input type="email" name="email" id="email" required class="w-full bg-gray-900 border border-gray-600 rounded px-4 py-2 focus:border-yellow-500 focus:outline-none transition text-white">
        </div>
        <div>
          <label for="password" class="block text-sm font-semibold text-gray-400 mb-1">Password</label>
          <input type="password" name="password" id="password" required class="w-full bg-gray-900 border border-gray-600 rounded px-4 py-2 focus:border-yellow-500 focus:outline-none transition text-white">
        </div>
        <button id="enter-btn" type="submit" class="w-full bg-indigo-700 hover:bg-indigo-600 text-white font-bold py-3 rounded shadow-md transition transform active:scale-95">
          Enter the Tavern
        </button>
      </form>
    </section>
  </div>
</div>