<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title><%= content_for(:title) || "DnD Ruby" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700&family=MedievalSharp&display=swap"  rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'MedievalSharp', cursive; }
        .hero-gradient {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1519074069444-1ba4fff66d16?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
        }
        .card-blur {
            background: rgba(31, 41, 55, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 215, 0, 0.2);
        }
    </style>

  </head>

  <body>
    <nav class="flex items-center px-8 py-6 bg-gray-900 border-b border-gray-800 sticky top-0 z-50">
        <div class="flex-1">
            <div class="text-2xl font-bold text-yellow-500 tracking-wider">DnD Ruby</div>
        </div>

        <div class="hidden md:flex space-x-8 text-sm uppercase tracking-widest justify-center">
            <a href="#features" class="hover:text-yellow-500 transition">Features</a>
            <a href="#campaigns" class="hover:text-yellow-500 transition">Campaigns</a>
        </div>

        <div class="flex-1 flex justify-end">
            <button class="bg-yellow-600 hover:bg-yellow-700 text-white px-6 py-2 rounded font-bold transition">
                Profile
            </button>
        </div>
    </nav>
    <%= yield %>
    <footer class="py-12 border-t border-gray-800 text-center">
        <div class="text-xl font-bold text-yellow-600 mb-4 uppercase tracking-tighter">DND Ruby</div>
        <p class="text-gray-500 text-sm">© 2026 DND Ruby. Not affiliated with Wizards of the Coast.</p>
        <div class="mt-6 flex justify-center space-x-6 text-gray-400">
            <a href="#" class="hover:text-white">X</a>
            <a href="#" class="hover:text-white">Discord</a>
            <a href="#" class="hover:text-white">Support</a>
        </div>
    </footer>
  </body>
</html>
